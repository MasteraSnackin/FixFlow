# Copy to .env.local and fill in values (never commit .env.local).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider selection
FIXFLOW_AI_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional Google fallback
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Optional web-retrieval backend for contractor discovery, vetting, and quote grounding
FIXFLOW_WEB_PROVIDER=brightdata
BRIGHTDATA_API_KEY=

# Telegram bot (Track 3 surface, optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_FIXFLOW_TENANT_ID=
TELEGRAM_FIXFLOW_UNIT_ID=
TELEGRAM_FIXFLOW_REQUEST_LANGUAGE=en-GB

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ElevenLabs (voice script generation, optional)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Twilio (phone call delivery for quote requests, optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Resend (email delivery for quote requests, optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Quote notification defaults
LANDLORD_OVERRIDE_PHONE=+447727821753
QUOTE_NOTIFY_EMAIL=mythicmindlabs@gmail.com

# Public base URL for Twilio webhooks (use ngrok for local dev: ngrok http 3000)
APP_URL=https://your-ngrok-url.ngrok-free.app

# Optional: base URL for server-side fetch to same deployment (vet/notify chain on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: workflow step fetch timeout for /api/vet, work-order, notify (ms, default 120000)
# WORKFLOW_INTERNAL_FETCH_TIMEOUT_MS=120000
